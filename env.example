# Copy this to .env and fill in your keys

# 1. Discord Bot Token — from discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# 2. Your Discord Server (Guild) ID — right-click your server → Copy Server ID
#    (Enable Developer Mode in Discord Settings → Advanced first)
GUILD_ID=your_guild_id_here

# 3. Google Gemini API Key (free) — aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Reddit: no key needed — the bot reads public posts via Reddit's JSON API.
